generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trips     Trip[]
}

model Trip {
  id          String      @id @default(cuid())
  userId      String?
  destination String
  dates       String
  travelers   String
  objective   String
  budget      String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User?       @relation(fields: [userId], references: [id])
  plans       TripPlan[]
  researchRuns ResearchRun[]
}

model TripPlan {
  id        String   @id @default(cuid())
  tripId    String
  provider  String
  content   Json
  createdAt DateTime @default(now())
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model LocalPartner {
  id          String   @id @default(cuid())
  name        String
  destination String
  category    String
  phone       String?
  email       String?
  website     String?
  rating      Float?
  source      String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contactLogs SupplierContactLog[]
}

model ResearchRun {
  id        String            @id @default(cuid())
  tripId    String?
  query     String
  provider  String
  status    String
  createdAt DateTime          @default(now())
  trip      Trip?             @relation(fields: [tripId], references: [id], onDelete: SetNull)
  findings  ResearchFinding[]
}

model ResearchFinding {
  id                      String      @id @default(cuid())
  researchRunId           String
  category                String
  title                   String
  description             String
  source                  String
  confidence              Float
  score                   Float?
  estimatedCost           String?
  locationHint            String?
  contactHint             String?
  requiresHumanValidation Boolean     @default(false)
  createdAt               DateTime    @default(now())
  researchRun             ResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)
}

model SupplierContactLog {
  id             String       @id @default(cuid())
  localPartnerId String?
  supplierName   String
  destination    String
  channel        String
  message        String
  status         String       @default("draft")
  createdAt      DateTime     @default(now())
  sentAt         DateTime?
  localPartner   LocalPartner? @relation(fields: [localPartnerId], references: [id], onDelete: SetNull)
}
